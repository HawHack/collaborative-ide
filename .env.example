COMPOSE_PROJECT_NAME=collaborative-ide

POSTGRES_DB=collab_ide
POSTGRES_USER=collab_ide
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost,http://127.0.0.1
BACKEND_PUBLIC_URL=http://localhost
SQLALCHEMY_DATABASE_URI=postgresql+psycopg://collab_ide:change_me_postgres_password@postgres:5432/collab_ide
ASYNC_SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://collab_ide:change_me_postgres_password@postgres:5432/collab_ide

JWT_SECRET_KEY=change_me_access_secret
JWT_REFRESH_SECRET_KEY=change_me_refresh_secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
SECURE_COOKIES=false

EXECUTOR_URL=http://executor:8010
EXECUTOR_SHARED_TOKEN=change_me_executor_token

COLLAB_URL=ws://localhost/ws/collab
COLLAB_INTERNAL_URL=ws://collab:3001

AI_PROVIDER=openai_compatible
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_SITE_URL=http://localhost
AI_APP_NAME=Collaborative IDE

EXECUTOR_PORT=8010
EXECUTOR_MAX_OUTPUT_BYTES=24000
EXECUTOR_TIMEOUT_SECONDS=10
EXECUTOR_MEMORY_LIMIT=256m
EXECUTOR_CPU_LIMIT=1.0
EXECUTOR_PIDS_LIMIT=64

COLLAB_SERVER_NAME=collab-main
